generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////
// ENUMS
//////////////////////////////

enum CampaignStatus {
  ACTIVE
  FINISHED
}

enum MemberRole {
  LEADER
  MEMBER
}

enum TurnStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum ActionType {
  RECRUIT
  ATTACK
  BUILD
  TRADE
  MOVE
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

enum RelationStatus {
  ALLY
  NEUTRAL
  HOSTILE
  WAR
}

//////////////////////////////
// GAME
//////////////////////////////

model Game {
  id          String @id @default(cuid())

  name        String @unique

  description String?

  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id     String @id @default(cuid())
  name   String

  status CampaignStatus @default(ACTIVE)

  currentTurn Int @default(1)

  currentYear Int @default(282)

  currentSeason String @default("Spring")

  gameId String
  game Game @relation(fields: [gameId], references: [id])

  factions Faction[]
  turns Turn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////
// FACTIONS
//////////////////////////////

model Faction {

  id String @id @default(cuid())

  name String

  description String?

  bonuses Json?

  telegramChatId String? @unique

  campaignId String

  campaign Campaign @relation(fields: [campaignId], references: [id])

  houses House[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////////////
// HOUSES
//////////////////////////////

model House {

  id String @id @default(cuid())

  name String

  description String?

  words String?

  telegramChatId String? @unique

  treasury Int @default(0)

  population Int @default(0)

  recruitablePopulation Int @default(0)

  influence Int @default(0)

  corruption Int @default(0)

  morale Int @default(100)

  supply Int @default(100)

  factionId String

  faction Faction @relation(fields:[factionId], references:[id])

  characters Character[]

  castle Castle?

  members FactionMember[]

  resources FactionResource[]

  productions Production[]

  units HouseUnit[]

  buildings HouseBuilding[]

  actions Action[]

  relationsFrom HouseRelation[] @relation("HouseA")

  relationsTo HouseRelation[] @relation("HouseB")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////////////
// Character
//////////////////////////////

model Character {

  id String @id @default(cuid())

  name String

  title String?

  description String?

  portraitUrl String?

  nickname String?
  
  authority Int @default(50)

  prestige Int @default(0)

  warfare Int @default(1)

  diplomacy Int @default(1)

  stewardship Int @default(1)

  intrigue Int @default(1)

  loyalty Int @default(100)

  age Int?

  isAlive Boolean @default(true)

  isLord Boolean @default(false)

  isCommander Boolean @default(false)

  houseId String

  house House @relation(fields:[houseId], references:[id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////////////
// CASTLE
//////////////////////////////

model Castle {

  id String @id @default(cuid())

  name String

  level Int @default(1)

  defenseLevel Int @default(100)

  garrisonBonus Int @default(0)

  houseId String @unique

  house House @relation(fields:[houseId], references:[id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////////////
// BUILDINGS
//////////////////////////////

model BuildingType {

  id String @id @default(cuid())

  name String

  icon String?

  description String?

  buildings HouseBuilding[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model HouseBuilding {

  id String @id @default(cuid())

  houseId String

  house House @relation(fields:[houseId], references:[id])

  buildingTypeId String

  buildingType BuildingType @relation(fields:[buildingTypeId], references:[id])

  level Int @default(1)

  productions Production[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([houseId, buildingTypeId])
}

//////////////////////////////
// RESOURCES
//////////////////////////////

model ResourceType {

  id String @id @default(cuid())

  name String

  description String?

  icon String?

  resources FactionResource[]

  productions Production[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model FactionResource {

  id String @id @default(cuid())

  amount Int @default(0)

  houseId String

  house House @relation(fields:[houseId], references:[id])

  resourceTypeId String

  resourceType ResourceType @relation(fields:[resourceTypeId], references:[id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([houseId, resourceTypeId])
}

//////////////////////////////
// PRODUCTION
//////////////////////////////

model Production {

  id String @id @default(cuid())

  houseId String

  house House @relation(fields:[houseId], references:[id])

  buildingId String

  building HouseBuilding @relation(fields:[buildingId], references:[id])

  resourceTypeId String

  resourceType ResourceType @relation(fields:[resourceTypeId], references:[id])

  amountPerTurn Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////////////
// UNITS
//////////////////////////////

model UnitType {

  id String @id @default(cuid())

  name String

  description String?

  icon String?

  power Int @default(1)

  upkeep Int @default(0)

  units HouseUnit[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model HouseUnit {

  id String @id @default(cuid())

  amount Int @default(0)

  houseId String

  house House @relation(fields:[houseId], references:[id])

  unitTypeId String

  unitType UnitType @relation(fields:[unitTypeId], references:[id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([houseId, unitTypeId])
}

//////////////////////////////
// RELATIONS
//////////////////////////////

model HouseRelation {

  id String @id @default(cuid())

  houseAId String

  houseA House @relation("HouseA", fields:[houseAId], references:[id])

  houseBId String

  houseB House @relation("HouseB", fields:[houseBId], references:[id])

  relation Int

  status RelationStatus

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([houseAId, houseBId])
}

//////////////////////////////
// PLAYERS
//////////////////////////////

model Player {

  id String @id @default(cuid())

  telegramId String @unique

  username String?

  firstName String?

  lastName String?

  isActive Boolean @default(true)

  factions FactionMember[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model FactionMember {

  id String @id @default(cuid())

  role MemberRole @default(MEMBER)

  playerId String

  player Player @relation(fields:[playerId], references:[id])

  houseId String

  house House @relation(fields:[houseId], references:[id])

  joinedAt DateTime @default(now())

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([playerId, houseId])
}

//////////////////////////////
// TURNS
//////////////////////////////

model Turn {

  id String @id @default(cuid())

  number Int

  status TurnStatus @default(PENDING)

  campaignId String

  campaign Campaign @relation(fields:[campaignId], references:[id])

  actions Action[]

  events Event[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([campaignId, number])
}

//////////////////////////////
// EVENTS
//////////////////////////////

model Event {

  id String @id @default(cuid())

  title String

  description String?

  effect Json?

  severity Int @default(1)

  visible Boolean @default(true)

  turnId String

  turn Turn @relation(fields:[turnId], references:[id])

  createdAt DateTime @default(now())
}

//////////////////////////////
// ACTIONS
//////////////////////////////

model Action {

  id String @id @default(cuid())

  type ActionType

  status ActionStatus @default(PENDING)

  payload Json?

  turnId String

  turn Turn @relation(fields:[turnId], references:[id])

  houseId String

  house House @relation(fields:[houseId], references:[id])

  processedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}